# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://schoolsync:schoolsync_dev_pass@localhost:5432/schoolsync_dev

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change_me_to_a_random_64_char_string_for_production
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_string_for_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Storage (S3-compatible)
S3_BUCKET=schoolsync-files
S3_REGION=me-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Notifications
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# License
LICENSE_ENCRYPTION_KEY=change_me_to_a_random_32_char_string

# RFID Card Encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RFID_ENCRYPTION_KEY=<generate-with-command-above>

# Partner Config
PARTNER_NAME=MSquare
PARTNER_DOMAIN=msquare-edu.com
DEFAULT_LOCALE=en
DEFAULT_TIMEZONE=Africa/Addis_Ababa
DEFAULT_CALENDAR=ETHIOPIAN
